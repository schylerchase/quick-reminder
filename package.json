{
  "name": "obsidian-quick-reminder",
  "version": "0.4.0",
  "description": "Natural-language task capture with native OS notifications for Obsidian.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "test": "node scripts/run-tests.mjs",
    "ui-qa": "playwright test --config ui-qa/playwright.config.ts",
    "ui-qa:update": "playwright test --config ui-qa/playwright.config.ts --update-snapshots",
    "release:package": "npm run build && node scripts/package-release.mjs"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "reminder",
    "tasks",
    "notifications"
  ],
  "author": "Schyler Ryan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schylerchase/quick-reminder.git"
  },
  "bugs": {
    "url": "https://github.com/schylerchase/quick-reminder/issues"
  },
  "homepage": "https://github.com/schylerchase/quick-reminder#readme",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.12",
    "obsidian": "^1.4.11",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "chrono-node": "^2.7.5"
  }
}
